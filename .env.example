# Copy to .env and fill in your values:
# cp .env.example .env

# Database
DR_DATABASE_URL=postgresql+psycopg2://daily_report:your_password@localhost:5432/daily_report

# LLM
DR_LLM_API_URL=http://localhost:11434
DR_LLM_MODEL=qwen2.5:7b-instruct-q4_K_M

# Redis
DR_REDIS_URL=redis://localhost:6379/0

# Processing
DR_BATCH_SIZE=50
DR_MAX_CONTEXT_TOKENS=2048

# Paths
DR_DATA_DIR=/path/to/your/documents
DR_NOTES_WATCH_DIR=/path/to/your/notes/folder
